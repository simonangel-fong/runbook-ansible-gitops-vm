# {{ ansible_managed }}
# Grafana dashboard provider — Phase H5.
#
# Tells Grafana to load any *.json file in /var/lib/grafana/dashboards as a
# dashboard. The role copies canary-dashboard.json there.

apiVersion: 1

providers:
  - name: gitops-vm
    orgId: 1
    folder: ""
    type: file
    disableDeletion: true
    updateIntervalSeconds: 10
    allowUiUpdates: false
    options:
      path: /var/lib/grafana/dashboards
      foldersFromFilesStructure: false
