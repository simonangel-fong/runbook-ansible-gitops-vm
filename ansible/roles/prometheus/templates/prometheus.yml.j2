# {{ ansible_managed }}
# Prometheus scrape config 

global:
  scrape_interval: 5s
  evaluation_interval: 5s
  external_labels:
    cluster: gitops-vm

scrape_configs:
  # Prometheus scrapes itself 
  - job_name: prometheus
    static_configs:
      - targets:
          - localhost:9090

  # The gitops-api fleet. host label is the VM name so PromQL queries that
  # distinguish canary vs stable can use it directly.
  - job_name: gitops-api
    metrics_path: /metrics
    static_configs:
      - targets:
          - "{{ hostvars['app-vm1'].ansible_host }}:8080"
        labels:
          host: app-vm1
          role: canary
      - targets:
          - "{{ hostvars['app-vm2'].ansible_host }}:8080"
        labels:
          host: app-vm2
          role: stable
    metric_relabel_configs:
      - regex: "^exported_host$"
        action: labeldrop
